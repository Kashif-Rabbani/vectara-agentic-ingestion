# SPARQL endpoint
# Option A — single base URL (auto-derives /query, /update, /data for Fuseki/Stardog)
SPARQL_ENDPOINT=http://localhost:3030/ds

# Option B — set each URL explicitly (for GraphDB, Virtuoso, Neptune, etc.)
# SPARQL_QUERY_URL=http://localhost:3030/ds/query
# SPARQL_UPDATE_URL=http://localhost:3030/ds/update
# SPARQL_GRAPH_STORE_URL=http://localhost:3030/ds/data

SPARQL_USERNAME=admin
SPARQL_PASSWORD=<fuseki-admin-password>
# When using setup_fuseki.sh (entrypoint bypassed), find the default password with:
#   docker exec jena-fuseki grep admin /fuseki/shiro.ini

# Vectara
# Production:  api.vectara.io  + zut_ personal key  (console.vectara.com)
# Dev console: api.vectara.dev + zrt_ Application API key (console.vectara.dev)
VECTARA_BASE_URL=https://api.vectara.dev/v2
VECTARA_API_KEY=<your-application-api-key>

# MCP server binding
MCP_HOST=0.0.0.0
MCP_PORT=8000
